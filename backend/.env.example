# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_matching_platform?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# OpenAI (for AI matching and chat)
OPENAI_API_KEY="sk-your-openai-api-key"

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Server
PORT=3000
NODE_ENV="development"

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://kindoraai.com,https://www.kindoraai.com"
